# Wing Optimizer Backend — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Default (used if not set): Vercel prod URL + localhost dev ports.
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# ── Flask ─────────────────────────────────────────────────────────────────────
# Set to 1 ONLY in local development. Never set in production.
# FLASK_DEBUG=0

# ── Server port ───────────────────────────────────────────────────────────────
# Railway sets this automatically. Override for local dev if needed.
# PORT=8000
